# RedlineBench API keys — copy to `.env` and fill in your own values.
# `.env` is gitignored; never commit real keys.

# Anthropic — claude-code agents + claude-haiku-4-5 panel judge
ANTHROPIC_API_KEY=

# OpenAI — codex agents + gpt-5.4-mini panel judge
OPENAI_API_KEY=

# Google / Gemini — opencode + gemini agents and the gemini-3.1-flash-lite panel judge
GOOGLE_GENERATIVE_AI_API_KEY=
GEMINI_API_KEY=

# Optional, for additional models: OpenRouter — opencode agents routed through OpenRouter
OPENROUTER_API_KEY=

# Optional: override the default 3-judge panel / single judge (LiteLLM model strings)
JUDGE_PANEL=
JUDGE_MODEL=
