{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "modal-kimi": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Modal Auto Endpoint - Kimi K2.6",
      "options": {
        "baseURL": "{env:MODAL_KIMI_AUTO_ENDPOINT_BASE_URL}",
        "headers": {
          "Modal-Key": "{env:MODAL_PROXY_TOKEN_ID}",
          "Modal-Secret": "{env:MODAL_PROXY_TOKEN_SECRET}"
        }
      },
      "models": {
        "nvidia/Kimi-K2.6-NVFP4": {
          "name": "Kimi K2.6 NVFP4"
        }
      }
    },
    "modal-qwen": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Modal Auto Endpoint - Qwen 3.6 27B FP8",
      "options": {
        "baseURL": "{env:MODAL_QWEN_AUTO_ENDPOINT_BASE_URL}",
        "headers": {
          "Modal-Key": "{env:MODAL_PROXY_TOKEN_ID}",
          "Modal-Secret": "{env:MODAL_PROXY_TOKEN_SECRET}"
        }
      },
      "models": {
        "Qwen/Qwen3.6-27B-FP8": {
          "name": "Qwen 3.6 27B FP8"
        }
      }
    }
  }
}
